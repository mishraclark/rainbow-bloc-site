---
import { getCollection } from "astro:content";

const now = new Date();
const allEvents = await getCollection("events");

const upcomingEvents = allEvents
  .filter((e) => e.data.start >= now)
  .sort((a, b) => a.data.start.getTime() - b.data.start.getTime());

function formatDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
  });
}

function formatTime(d: Date): string {
  return d.toLocaleTimeString("en-US", {
    hour: "numeric",
    minute: "2-digit",
  });
}
---

{upcomingEvents.length > 0 ? (
  <ul class="event-list">
    {upcomingEvents.map((event) => (
      <li class="event-card">
        {event.data.image && (
          <img src={event.data.image} alt={event.data.name} class="event-image" />
        )}
        <div class="event-info">
          <div class="event-date">{formatDate(event.data.start)}</div>
          <div class="event-details">
            <strong class="event-name">{event.data.name}</strong>
            <span class="event-time">
              {formatTime(event.data.start)}
              {event.data.end && ` – ${formatTime(event.data.end)}`}
            </span>
            {event.data.location && (
              <span class="event-location">{event.data.location}</span>
            )}
            {event.data.description && (
              <p class="event-description">{event.data.description}</p>
            )}
            {event.data.link && (
              <a href={event.data.link} target="_blank" rel="noopener" class="event-link">
                More info
              </a>
            )}
          </div>
        </div>
      </li>
    ))}
  </ul>
) : (
  <p class="no-events">No upcoming events right now — check back soon!</p>
)}

<style>
  .event-list {
    list-style: none;
    padding: 0;
    margin: 2rem auto 0;
    max-width: 40rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .event-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius, 0.5rem);
    border: 1px solid var(--color-border, #e5e7eb);
    background: var(--color-bg, #fff);
  }

  .event-image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius, 0.5rem);
  }

  .event-info {
    display: flex;
    gap: 1.5rem;
  }

  .event-date {
    flex-shrink: 0;
    font-weight: 600;
    color: #006693;
    min-width: 5rem;
  }

  .event-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .event-name {
    font-size: 1.05rem;
  }

  .event-time,
  .event-location {
    font-size: 0.9rem;
    color: var(--color-muted, #6b7280);
  }

  .event-description {
    margin-top: 0.25rem;
    font-size: 0.9rem;
  }

  .event-link {
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .no-events {
    color: var(--color-muted, #6b7280);
    margin-top: 1rem;
  }
</style>
