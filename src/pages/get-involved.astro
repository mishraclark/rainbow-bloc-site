---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Get Involved | Rainbow Bloc">
  <section>
    <div class="container">
      <h1>Get Involved</h1>
      <p>There are many ways to support Rainbow Bloc and our community. Find what works for you.</p>

      <div class="grid grid-2" style="margin-top: 2rem;">
        <div class="card">
          <h3>Volunteer</h3>
          <p>Join us at events, help with outreach, or contribute your skills.</p>
          <a href="/about/contact">Get in touch</a>
        </div>
        <div class="card">
          <h3>Spread the Word</h3>
          <p>Print and share zines, tell your friends, post on social media.</p>
          <a href="/stay-informed/zines">Browse zines</a>
        </div>
        <div class="card">
          <h3>Attend Events</h3>
          <p>Show up, learn, and build community together.</p>
          <a href="/stay-informed/calendar">See upcoming events</a>
        </div>
        <div class="card">
          <h3>Donate</h3>
          <p>Financial support helps us print materials, host events, and keep going.</p>
          <a href="/about/donate">Support us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
