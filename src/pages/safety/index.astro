---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Safety | Rainbow Bloc">
  <section>
    <div class="container">
      <h1>Safety Resources</h1>
      <p>Protecting our community — online and in person.</p>

      <div class="grid grid-2" style="margin-top: 2rem;">
        <div class="card">
          <h2>Digital Safety</h2>
          <p>Secure your communications and protect your identity online.</p>
          <ul>
            <li>Use Signal for encrypted messaging</li>
            <li>Keep software up to date</li>
            <li>Use strong, unique passwords</li>
          </ul>
          <!-- TODO: expand with org-specific guidance, Signal group links, etc. -->
        </div>
        <div class="card">
          <h2>Physical Safety</h2>
          <p>Stay safe at actions, protests, and in your community.</p>
          <ul>
            <li>Know your rights</li>
            <li>Use the buddy system</li>
            <li>Have an emergency contact plan</li>
          </ul>
          <!-- TODO: expand with org-specific guidance -->
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
