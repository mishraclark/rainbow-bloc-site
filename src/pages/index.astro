---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Rainbow Bloc">
  <section class="hero">
    <div class="container">
      <img src="/rb-logo.svg" alt="Rainbow Bloc" class="hero-logo" />
      <p class="hero-tagline">Solidarity in action.</p>
      <div class="hero-actions">
        <a href="/get-involved" class="btn btn-primary">Get Involved</a>
        <a href="/causes" class="btn btn-outline">Our Causes</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>What We Do</h2>
      <div class="grid grid-3">
        <div class="card">
          <h3>Causes</h3>
          <p>Standing in solidarity with communities facing injustice — from ICE resistance to mutual aid.</p>
          <a href="/causes">Learn more</a>
        </div>
        <div class="card">
          <h3>Stay Informed</h3>
          <p>Zines, events, and resources to keep you connected and informed.</p>
          <a href="/stay-informed">Learn more</a>
        </div>
        <div class="card">
          <h3>Safety</h3>
          <p>Digital security and physical safety resources for our community.</p>
          <a href="/safety">Learn more</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Get Involved</h2>
      <p>Whether you can volunteer time, share resources, or spread the word — there's a place for you.</p>
      <a href="/get-involved" class="btn btn-primary">See how you can help</a>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Support Our Work</h2>
      <p>Your donations keep our programs running and our community safe.</p>
      <a href="/about/donate" class="btn btn-outline">Donate</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 5rem 3rem;
    text-align: center;
  }

  .hero-logo {
    width: min(80%, 28rem);
    height: auto;
    margin-top: -7.5rem;

  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--color-muted);
    margin-top: -10rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>
