---
import BaseLayout from "../layouts/BaseLayout.astro";
import Faq from "../components/Faq.astro";
import UpcomingEvents from "../components/UpcomingEvents.astro";

const whistleFilesUrl = "https://drive.proton.me/urls/KT1VB9Q0Z0#MoCjM8uCwoTr";

const showCalendar = false;
const calendarId = "REPLACE_WITH_CALENDAR_ID@group.calendar.google.com";
const calendarTimezone = "America/Los_Angeles";
const calendarEmbedUrl = `https://calendar.google.com/calendar/embed?src=${encodeURIComponent(calendarId)}&ctz=${encodeURIComponent(calendarTimezone)}&mode=AGENDA&showTitle=0&showPrint=0&showCalendars=0&showTz=0`;
const calendarPublicUrl = `https://calendar.google.com/calendar/u/0/r?cid=${encodeURIComponent(calendarId)}`;

const whistleFaq = [
  {
    question: "Which whistle file should I print?",
    answer: `<p>We suggest printing one of the files in <a href="${whistleFilesUrl}" target="_blank" rel="noopener">this folder</a>, as they have the best combination of speed, filament usage, and loudness.</p><p>All types of whistles are accepted, though.</p>`,
  },
  {
    question: "Do I need to print the PIRC Hotline # on the whistles?",
    answer: `<p><strong>Nope!</strong></p><p>The hotline is on every flyer that comes with a whistle, and overwhelming feedback is that folks save the hotline # to their phones, rather than reading it off the whistle in the moment.</p><p>We included the whistles that have the PIRC # printed directly on them, as that is a common question, but you do NOT need to print the #. If the STL without the # prints faster or with less filament, please use that one.</p>`,
  },
  {
    question: "What color should I use?",
    answer: `<p>Any color or combination of colors!</p>`,
  },
  {
    question: "What filament should I use?",
    answer: `<p>Any filament! The files have been tested with many brands.</p>`,
  },
  {
    question: "How many whistles should I print?",
    answer: `<p>As many as you reasonably can!</p><p>The weekly builds are large, and we estimate building 5–8k kits each week, depending on whistles supplied.</p>`,
  },
  {
    question: "How can I get the whistles to you?",
    answer: `<ul><li><strong>Dropoff at one of our events:</strong> 6–8pm at Lucky Lab on Hawthorne, every Wednesday in February</li><li><strong>Dropoff at a location in inner SE:</strong> 24/7, address shared in Signal only</li><li><strong>Pickup is available</strong> depending on neighborhood — please message in Signal or email <a href="mailto:rainbowbloc@proton.me">rainbowbloc@proton.me</a></li></ul>`,
  },
  {
    question: "Can I be reimbursed for the cost of filament?",
    answer: `<p><strong>Yes!</strong></p><p>We appreciate if you are able to donate the cost of filament, but we're happy to reimburse if that isn't possible. For new printers, the reimbursement cap is $20/week. That cap can increase if you regularly supply large batches.</p><p>To be reimbursed, message one of the admins in the 3D printing Signal chat, or email <a href="mailto:rainbowbloc@proton.me">rainbowbloc@proton.me</a>.</p><p>Please include:</p><ul><li>A receipt</li><li>A picture of the whistles</li><li>A rough count of whistles</li><li>Your Venmo (if you do not have Venmo, message us and we can work out another option)</li></ul>`,
  },
  {
    question: "How can I join the Signal chat for 3D printers?",
    answer: `<p>DM <a href="https://instagram.com/rainbowbloc" target="_blank" rel="noopener">@rainbowbloc</a> on IG or email <a href="mailto:rainbowbloc@proton.me">rainbowbloc@proton.me</a>.</p>`,
  },
];
---

<BaseLayout title="Rainbow Bloc">
  <section class="hero">
    <div class="container">
      <img src="/rb-logo.svg" alt="Rainbow Bloc" class="hero-logo" />
      <p class="hero-tagline">Solidarity in action.</p>
      <div class="hero-actions">
        <a href="mailto:rainbowbloc@proton.me?subject=Volunteering%20with%20Rainbow%20Bloc" class="btn btn-primary">Get Involved</a>
        <a href="/causes" class="btn btn-outline">Our Causes</a>
      </div>
    </div>
  </section>

  <section id="events" class="section-tinted">
    <div class="container">
      <h2>Upcoming Events</h2>
      <UpcomingEvents />
    </div>
  </section>

  {false && (
  <section>
    <div class="container">
      <h2>What We Do</h2>
      <div class="grid grid-3">
        <div class="card">
          <h3>Causes</h3>
          <p>Standing in solidarity with communities facing injustice — from ICE resistance to mutual aid.</p>
          <a href="/causes">Learn more</a>
        </div>
        <div class="card">
          <h3>Stay Informed</h3>
          <p>Zines, events, and resources to keep you connected and informed.</p>
          <a href="/stay-informed">Learn more</a>
        </div>
        <div class="card">
          <h3>Safety</h3>
          <p>Digital security and physical safety resources for our community.</p>
          <a href="/safety">Learn more</a>
        </div>
      </div>
    </div>
  </section>
  )}

  {showCalendar && (
  <section>
    <div class="container">
      <h2>Upcoming Events</h2>
      <p>See what's coming up and add events to your own calendar with one click.</p>
      <div class="calendar-embed">
        <iframe
          src={calendarEmbedUrl}
          title="Rainbow Bloc upcoming events"
          loading="lazy"
        ></iframe>
      </div>
      <p class="calendar-subscribe">
        <a href={calendarPublicUrl} class="btn btn-outline" target="_blank" rel="noopener">
          Add this calendar to Google Calendar
        </a>
      </p>
    </div>
  </section>
  )}

  <section id="printing" class="feature-section">
    <div class="container">
      <h2>Printing Whistles with Rainbow Bloc</h2>
      <p class="lead">
        Thank you for joining the fight against ICE! We host public weekly events where we build whistle kits, fold zines, and discuss best practices on individual and community safety.
      </p>
      <p class="zine-download">
        <a href="/downloads/zines/whistle-codes-8pp-eng-span.pdf" class="btn btn-outline" target="_blank">
          Download Whistle Codes Zine (PDF)
        </a>
        <a href={whistleFilesUrl} class="btn btn-outline" target="_blank" rel="noopener">
          Download Whistle 3D Print Files
        </a>
      </p>
      {/* <Faq items={whistleFaq} /> */}
    </div>
  </section>

  <section id="request" class="section-tinted">
    <div class="container">
      <h2>Request Whistles</h2>
      <p>You are welcome to pick up whistles from any of our events, or email us to coordinate a large batch. Please include an estimate of whistles needed and the groups you work with, if any.</p>
      <a href="mailto:rainbowbloc@proton.me?subject=Requesting%20Bulk%20Whistles" class="btn btn-primary" style="margin-top: 1.5rem;">Request Whistles</a>
    </div>
  </section>

  <section id="get-involved">
    <div class="container">
      <h2>Get Involved</h2>
      <p>Reach out to enquire about volunteer opportunities.</p>
      <a href="mailto:rainbowbloc@proton.me?subject=Volunteering%20with%20Rainbow%20Bloc" class="btn btn-primary" style="margin-top: 1.5rem;">See how you can help</a>
    </div>
  </section>

  <section id="support" class="section-tinted">
    <div class="container">
      <h2>Support Our Work</h2>
      <p>Your donations help us print zines, host events, and support our community.</p>
      <div class="venmo-qr">
        <a href="https://venmo.com/code?user_id=4039059722733486125&created=1769639015" target="_blank" rel="noopener">
          <img src="/qr-codes/rb-venmo-qr-code.svg" alt="Venmo QR code" />
        </a>
        <p>Scan the QR code or tap it to open Venmo.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  section {
    text-align: center;
    padding-block: 3rem;
  }

  section h2 {
    margin-block: 0 1.5rem;
  }

  .section-tinted {
    background-color: #e6f3f8;
  }

  .hero {
    padding-block: 5rem 3rem;
  }

  .hero-logo {
    width: min(80%, 28rem);
    height: auto;
    margin-top: -5rem;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--color-muted);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }

  .feature-section .lead {
    font-size: 1.1rem;
    max-width: 50rem;
    margin-bottom: 2rem;
    margin-inline: auto;
  }

  .zine-download {
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .calendar-embed {
    margin-top: 1.5rem;
    border: 1px solid var(--color-border, #ddd);
    border-radius: 0.5rem;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    max-width: 50rem;
    margin-inline: auto;
  }

  .calendar-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .calendar-subscribe {
    margin-top: 1rem;
  }

  .venmo-qr {
    margin-top: 1.5rem;
    text-align: center;
    max-width: 24rem;
    margin-inline: auto;
  }

  .venmo-qr img {
    width: 12rem;
    height: auto;
    margin-bottom: 1rem;
  }

  @media (min-width: 48rem) {
    .calendar-embed {
      aspect-ratio: 16 / 9;
    }
  }
</style>
