---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Donate | Rainbow Bloc">
  <section>
    <div class="container">
      <h1>Support Our Work</h1>
      <p>Your donations help us print zines, host events, and support our community.</p>
      <div class="card" style="margin-top: 2rem; max-width: 24rem; text-align: center;">
        <h3>Donate via Venmo</h3>
        <img src="/qr-codes/rb-venmo-qr-code.svg" alt="Venmo QR code" class="qr-code" />
        <p>Scan the QR code or find us on Venmo.</p>
      </div>
    </div>
  </section>

<style>
  .qr-code {
    width: 12rem;
    height: auto;
    margin-block: 1rem;
  }
</style>
</BaseLayout>
